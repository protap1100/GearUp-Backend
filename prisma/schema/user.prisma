model User {

  id          String   @id @default(uuid())

  name        String
  email       String   @unique
  password    String

  role        Role     @default(CUSTOMER)

  phone       String?
  address     String?

  // status      UserStatus @default(ACTIVE)

  // Provider relation
  // gears       GearItem[]


  // Customer relation
  // rentals     RentalOrder[]

  // reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}