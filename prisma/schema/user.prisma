model User {
  id           String      @id @default(uuid())

  name         String
  email        String      @unique
  password     String

  role         Role        @default(CUSTOMER)
  status       UserStatus  @default(ACTIVE)

  phone        String?
  address      String?
  profilePhoto String?

  // Provider
  gearItems    GearItem[]

  // Customer
  rentals      RentalOrder[]
  reviews      Review[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}